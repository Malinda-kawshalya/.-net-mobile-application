<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- FlavorVault Recipe App - Warm Food Theme -->
    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <!-- Primary: Warm Orange -->
    <Color x:Key="Primary">#E85D2C</Color>
    <Color x:Key="PrimaryDark">#FF8A65</Color>
    <Color x:Key="PrimaryDeep">#B8421B</Color>
    <Color x:Key="PrimarySoft">#FFE4D7</Color>
    <Color x:Key="PrimaryDarkText">#1A1210</Color>

    <!-- Secondary: Fresh Green -->
    <Color x:Key="Secondary">#2E7D32</Color>
    <Color x:Key="SecondaryLight">#A5D6A7</Color>
    <Color x:Key="SecondaryDarkText">#66BB6A</Color>
    <Color x:Key="SecondaryMuted">#5C8D63</Color>

    <!-- Tertiary: Golden Yellow (ratings, stars) -->
    <Color x:Key="Tertiary">#F9A825</Color>

    <!-- Neutrals -->
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="OffBlack">#1A1210</Color>
    <Color x:Key="MidnightBlue">#191970</Color>
    <Color x:Key="Magenta">#D81B60</Color>

    <!-- Backgrounds -->
    <Color x:Key="BackgroundLight">#FFF6EE</Color>
    <Color x:Key="BackgroundSoft">#FFF1E3</Color>
    <Color x:Key="BackgroundDark">#1A1210</Color>
    <Color x:Key="SurfaceLight">#FFFFFF</Color>
    <Color x:Key="SurfaceDark">#2C2220</Color>
    <Color x:Key="SurfaceVariant">#FFF0E6</Color>
    <Color x:Key="SurfaceElevatedLight">#FFFFFF</Color>
    <Color x:Key="SurfaceElevatedDark">#322826</Color>

    <!-- Text colors -->
    <Color x:Key="OnBackgroundLight">#2C1810</Color>
    <Color x:Key="OnBackgroundDark">#F5E6D8</Color>
    <Color x:Key="OnSurfaceLight">#3E2723</Color>
    <Color x:Key="OnSurfaceDark">#EFEBE9</Color>

    <!-- Outline / borders -->
    <Color x:Key="Outline">#D7CCC8</Color>
    <Color x:Key="OutlineDark">#5D4037</Color>
    <Color x:Key="OutlineSoft">#EFE1D8</Color>

    <!-- Tab bar colors -->
    <Color x:Key="TabBarBackgroundLight">#FFFDF9</Color>
    <Color x:Key="TabBarBackgroundDark">#241B18</Color>
    <Color x:Key="TabBarSelectedLight">#D65126</Color>
    <Color x:Key="TabBarSelectedDark">#FFB08F</Color>
    <Color x:Key="TabBarUnselectedLight">#8A766A</Color>
    <Color x:Key="TabBarUnselectedDark">#B4A49D</Color>
    <Color x:Key="TabBarDisabledLight">#C7B8AF</Color>
    <Color x:Key="TabBarDisabledDark">#6C5C54</Color>

    <!-- Grays (retained for system styles compatibility) -->
    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

    <!-- Status colors -->
    <Color x:Key="Success">#4CAF50</Color>
    <Color x:Key="Warning">#FF9800</Color>
    <Color x:Key="Error">#F44336</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>
</ResourceDictionary>