<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Recipes_app.ViewModels"
             xmlns:models="clr-namespace:Recipes_app.Models"
             x:Class="Recipes_app.Views.RecipeListPage"
             x:DataType="vm:RecipeListViewModel"
             Title="{Binding Title}"
             BackgroundColor="{AppThemeBinding Light={StaticResource BackgroundLight}, Dark={StaticResource BackgroundDark}}">

    <Grid RowDefinitions="Auto,*">
        <!-- Search Bar -->
        <Border Style="{StaticResource ElevatedCardBorder}"
            StrokeShape="RoundRectangle 12"
                Margin="16,10"
                Padding="4,0">
            <SearchBar Text="{Binding SearchQuery}"
                       Placeholder="Search recipes..."
                       SearchCommand="{Binding SearchCommand}"
                       BackgroundColor="Transparent"
                       CancelButtonColor="{StaticResource Primary}" />
        </Border>

        <!-- Recipe List -->
        <RefreshView Grid.Row="1"
                     Command="{Binding LoadRecipesCommand}"
                     IsRefreshing="{Binding IsRefreshing}">
            <CollectionView ItemsSource="{Binding Recipes}"
                            Margin="16,0"
                            RemainingItemsThreshold="5">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical"
                                     Span="2"
                                     HorizontalItemSpacing="12"
                                     VerticalItemSpacing="12" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Recipe">
                        <Border Style="{StaticResource ElevatedCardBorder}"
                            StrokeShape="RoundRectangle 14"
                                Padding="0">
                            <VerticalStackLayout>
                                <Border StrokeShape="RoundRectangle 14,14,0,0"
                                        Stroke="Transparent"
                                        HeightRequest="130">
                                    <Image Source="{Binding ImageUrl}"
                                           Aspect="AspectFill" />
                                </Border>
                                <VerticalStackLayout Padding="10,8" Spacing="4">
                                    <Label Text="{Binding Title}"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation"
                                           TextColor="{AppThemeBinding Light={StaticResource OnSurfaceLight}, Dark={StaticResource OnSurfaceDark}}" />
                                    <HorizontalStackLayout Spacing="8">
                                        <HorizontalStackLayout Spacing="3">
                                            <Label Text="⏱" FontSize="11" />
                                            <Label Text="{Binding CookTimeMinutes, StringFormat='{0}m'}"
                                                   FontSize="11"
                                                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
                                        </HorizontalStackLayout>
                                        <HorizontalStackLayout Spacing="3">
                                            <Label Text="⭐" FontSize="11" />
                                            <Label Text="{Binding Rating, StringFormat='{0:F1}'}"
                                                   FontSize="11"
                                                   TextColor="{StaticResource Tertiary}" />
                                        </HorizontalStackLayout>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:RecipeListViewModel}}, Path=GoToRecipeDetailCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10" Padding="40">
                        <Label Text="🔍" FontSize="48" HorizontalOptions="Center" />
                        <Label Text="{Binding IsEmptyState, StringFormat='No recipes found'}"
                               IsVisible="{Binding IsEmptyState}"
                               Style="{StaticResource MutedCaptionLabel}"
                               FontSize="16"
                               HorizontalTextAlignment="Center"
                               />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>
        </RefreshView>

        <!-- Loading -->
        <ActivityIndicator Grid.Row="1"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="{StaticResource Primary}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
    </Grid>
</ContentPage>
